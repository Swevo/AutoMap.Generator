<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <IsRoslynComponent>true</IsRoslynComponent>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>

    <IncludeBuildOutput>false</IncludeBuildOutput>
    <NoWarn>$(NoWarn);NU5017;NU5128;RS2008;RS1035;RS1038;RS1019</NoWarn>

    <PackageId>AutoMap.Generator</PackageId>
    <Version>1.12.0</Version>
    <Authors>Justin Bannister</Authors>
    <Copyright>Copyright (c) 2026 Justin Bannister</Copyright>
    <Description>Compile-time object mapping for .NET via Roslyn source generators. Add [Map(typeof(Dto))] to your domain class — AutoMap generates strongly-typed ToDto() extension methods at build time. Zero reflection, zero startup overhead, AOT-safe, MAUI-compatible. Supports nested objects, collections, records, structs, enums, flattening, reverse mapping, and conditional mapping. Build-time diagnostics (AM001–AM007) catch mistakes at compile time, not runtime. Drop-in AutoMapper alternative; no profiles, no IMapper, no DI required. Attribute-first ergonomics — annotate once, call the extension method everywhere.</Description>
    <PackageTags>source-generator;roslyn;object-mapping;mapper;dto;compile-time;zero-reflection;automapper-alternative;mapperly-alternative;aot;maui;dotnet;csharp;record;struct;code-generation;mapping;dto-mapper;net8;net9</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RepositoryUrl>https://github.com/Swevo/AutoMap.Generator</RepositoryUrl>
    <PackageProjectUrl>https://swevo.github.io/AutoMap.Generator/</PackageProjectUrl>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageIcon>icon.png</PackageIcon>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <IncludeSymbols>false</IncludeSymbols>
    <Deterministic>true</Deterministic>
    <ContinuousIntegrationBuild Condition="'$(CI)' == 'true'">true</ContinuousIntegrationBuild>
    <PackageReleaseNotes>1.12.0: GenerateProjection = true on [Map]/[MapFrom] generates an Expression&lt;Func&lt;TSource,TDest&gt;&gt; + IQueryable&lt;TDest&gt; projection extension (ProjectToXxx), so EF Core can translate the mapping into SQL — equivalent to AutoMapper's ProjectTo. AM008 diagnostic warns when a mapping is incompatible with expression trees (null-conditional access or switch expressions). 1.11.1: Fix SimpleName stripping global:: prefix — IAutoMapper class now generates correctly for types in the global namespace (top-level statements programs). 1.11.0: Reverse = true on [Map] and [MapFrom] 1.10.0: AM004 code-fix provider (Add [MapIgnore] lightbulb). 1.9.0: Collection-level extension methods (orders.ToOrderDtos()). 1.8.0: [TrimStrings], [MapFormat], IMapFrom&lt;T&gt; convention, partial On{Method} hooks, Strict mode. 1.7.0: [MapWhen] conditional mapping. 1.6.0: Cross-enum mapping + [MapEnum]. 1.5.0: Flattening + [MapDefault]. 1.4.0: [MapWith]. 1.3.0: Constructor mapping. 1.2.0: Reverse + IAutoMapper. 1.1.0: Nested + collections. 1.0.0: Initial.</PackageReleaseNotes>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.*" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="4.*" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="3.*" PrivateAssets="all">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.*" PrivateAssets="all">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <None Include="..\..\icon.png" Pack="true" PackagePath="\" />
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
    <None Include="$(OutputPath)$(AssemblyName).dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
    <None Include="build\AutoMap.Generator.props" Pack="true" PackagePath="build\" />
  </ItemGroup>
</Project>
